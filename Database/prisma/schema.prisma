generator client {
  provider = "prisma-client-js"
  output   = "../../shared/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"

}

enum PhaseType {
  MENSTRUAL
  FOLLICULAR
  OVULATION
  LUTEAL
}

model User {
  id                 String   @id @default(uuid())
  name               String
  whatsappNumber     String   @unique
  age                Int?
  insightPreferences String?
  createdAt          DateTime @default(now())

  cycleLogs     CycleLog[]
  sleepLogs     SleepLog[]
  dailyLogs     DailyLog[]
  weeklyReports WeeklyReport[]

  @@map("users")
}

model CycleLog {
  id          String   @id @default(uuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime?
  cycleLength Int?
  createdAt   DateTime @default(now())

  user        User              @relation(fields: [userId], references: [id])
  predictions CyclePrediction[]

  @@map("cycle_logs")
}

model CyclePrediction {
  id                   String   @id @default(uuid())
  cycleLogId           String
  predictedPeriodStart DateTime
  predictedPeriodEnd   DateTime?
  ovulationDate        DateTime
  createdAt            DateTime @default(now())

  cycleLog             CycleLog      @relation(fields: [cycleLogId], references: [id])
  phases               CyclePhase[]

  @@map("cycle_predictions")
}

model CyclePhase {
  id           String    @id @default(uuid())
  predictionId String
  phaseType    PhaseType
  phaseStart   DateTime
  phaseEnd     DateTime

  prediction   CyclePrediction @relation(fields: [predictionId], references: [id])
  dailyLogs    DailyLog[]

  @@map("cycle_phases")
}

model SleepLog {
  id         String   @id @default(uuid())
  userId     String
  sleepDate  DateTime
  sleepHours Float
  recordedAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  dailyLogs  DailyLog[]

  @@unique([userId, sleepDate])
  @@map("sleep_logs")
}

model DailyLog {
  id                 String   @id @default(uuid())
  userId             String
  phaseId            String
  sleepLogId         String?
  logDate            DateTime
  recommendationSent String?
  
  user      User       @relation(fields: [userId], references: [id])
  phase     CyclePhase @relation(fields: [phaseId], references: [id])
  sleepLog  SleepLog?  @relation(fields: [sleepLogId], references: [id])

  @@map("daily_logs")
}

model WeeklyReport {
  id              String   @id @default(uuid())
  userId          String
  weekNumber      Int
  sleepAverage    Float?
  engagementScore Float?
  summaryText     String?
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])

  @@map("weekly_reports")
}